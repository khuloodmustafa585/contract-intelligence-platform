# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/contract_db

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── SMTP (Gmail example) ──────────────────────────────────────────────────────
# Steps to get Gmail App Password:
#   1. Enable 2-Step Verification: https://myaccount.google.com/security
#   2. Go to Security → App passwords
#   3. Select app: "Mail", device: "Other (Custom name)" → name it "Contract Lens"
#   4. Copy the 16-character password shown — use it as SMTP_PASSWORD below
#   5. Use your full Gmail address as SMTP_USERNAME and SMTP_FROM_EMAIL
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM_EMAIL=you@gmail.com

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
